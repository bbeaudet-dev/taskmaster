{
  "name": "taskmaster",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "convex": "^1.42.1",
      "better-auth": "1.6.15",
      "@better-auth/expo": "1.6.15",
      "@convex-dev/better-auth": "^0.12.5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:native": "turbo run dev -F native",
    "dev:server": "turbo run dev -F @taskmaster/backend",
    "dev:setup": "turbo run dev:setup -F @taskmaster/backend",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@taskmaster/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@taskmaster/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.10.2",
    "typescript": "^6"
  },
  "packageManager": "bun@1.2.15"
}
